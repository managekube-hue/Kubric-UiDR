# Kubric Portal — Next.js 14 standalone build
# next.config.js sets output: "standalone" — minimal production image.
#
# Usage:
#   docker build -f Dockerfile.web -t kubric/web:latest .

# ?? Stage 1: deps ?????????????????????????????????????????????????????????????
FROM node:22-alpine AS deps

RUN apk add --no-cache libc6-compat
WORKDIR /app

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --prefer-offline

# ?? Stage 2: builder ??????????????????????????????????????????????????????????
FROM node:22-alpine AS builder

WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY frontend/ .

# Build args injected at build time (baked into static bundle)
ARG NEXT_PUBLIC_API_BASE=http://ksvc:8080
ARG NEXT_PUBLIC_KAI_URL=http://kai:8101
ARG NEXT_PUBLIC_NATS_WS_URL=ws://nats:9222

ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
ENV NEXT_PUBLIC_KAI_URL=$NEXT_PUBLIC_KAI_URL
ENV NEXT_PUBLIC_NATS_WS_URL=$NEXT_PUBLIC_NATS_WS_URL
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

RUN npm run build

# ?? Stage 3: runner ???????????????????????????????????????????????????????????
FROM node:22-alpine AS runner

RUN apk add --no-cache dumb-init

WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3001
ENV HOSTNAME=0.0.0.0

# Non-root user
RUN addgroup --system --gid 1001 nodejs
RUN adduser  --system --uid 1001 nextjs

# Standalone output
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static     ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public           ./public

USER nextjs
EXPOSE 3001

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "server.js"]
