# =============================================================================
# Kubric Caddyfile — Unified reverse proxy for all platform services.
#
# In docker-compose the Caddy container routes by path prefix on :80.
# Production: swap :80 for domain blocks and enable auto-TLS.
# =============================================================================
{
	admin off
}

# Single-host dev config — all services under localhost:80
:80 {
	encode zstd gzip

	log {
		format json
	}

	# Security headers on every response
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# ── K-SVC: Tenant management API ────────────────────────────────────
	handle_path /api/v1/tenants* {
		reverse_proxy ksvc:8080
	}

	# ── VDR: Vulnerability findings ─────────────────────────────────────
	handle_path /api/v1/findings* {
		reverse_proxy vdr:8081
	}
	handle_path /api/v1/scans* {
		reverse_proxy vdr:8081
	}

	# ── KIC: Compliance assessments ─────────────────────────────────────
	handle_path /api/v1/assessments* {
		reverse_proxy kic:8082
	}
	handle_path /api/v1/frameworks* {
		reverse_proxy kic:8082
	}

	# ── NOC: Cluster & agent heartbeat ──────────────────────────────────
	handle_path /api/v1/clusters* {
		reverse_proxy noc:8083
	}
	handle_path /api/v1/agents* {
		reverse_proxy noc:8083
	}
	handle_path /api/v1/detection* {
		reverse_proxy noc:8083
	}
	handle /webhooks/falco* {
		reverse_proxy noc:8083
	}

	# ── KAI: AI orchestration (Go gateway → Python backend) ────────────
	handle /kai/* {
		reverse_proxy kai:8100
	}
	handle /v1/triage* {
		reverse_proxy kai:8100
	}
	handle /v1/score/* {
		reverse_proxy kai:8100
	}
	handle /v1/insights/* {
		reverse_proxy kai:8100
	}
	handle /v1/remediate* {
		reverse_proxy kai:8100
	}

	# ── Grafana dashboards ──────────────────────────────────────────────
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# ── Temporal UI ─────────────────────────────────────────────────────
	handle /temporal/* {
		reverse_proxy temporal-ui:8080
	}

	# ── n8n workflow automation ─────────────────────────────────────────
	handle /n8n/* {
		reverse_proxy n8n:5678
	}

	# ── MinIO console ──────────────────────────────────────────────────
	handle /minio/* {
		reverse_proxy minio:9001
	}

	# ── Health probe for Caddy itself ──────────────────────────────────
	handle /healthz {
		respond "ok" 200
	}

	# ── Default: 404 for unmatched routes ──────────────────────────────
	handle {
		respond "Not Found" 404
	}
}
