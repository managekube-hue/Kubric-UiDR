<?xml version="1.0" encoding="UTF-8"?>
<!--
  ClickHouse users.xml – Kubric UiDR Local Development
  ─────────────────────────────────────────────────────
  Defines users, profiles, quotas and network restrictions for the
  local ClickHouse instance that stores telemetry, flow and metric
  data (kubric_telemetry database).

  Mount into the ClickHouse container at:
    /etc/clickhouse-server/users.d/kubric_users.xml
-->
<clickhouse>

  <!-- ─────────── Profiles ─────────── -->
  <profiles>

    <!-- Default profile – conservative limits for interactive queries. -->
    <default>
      <max_memory_usage>4000000000</max_memory_usage>          <!-- 4 GB -->
      <max_memory_usage_for_user>8000000000</max_memory_usage_for_user> <!-- 8 GB -->
      <max_execution_time>120</max_execution_time>             <!-- 2 min -->
      <max_rows_to_read>500000000</max_rows_to_read>           <!-- 500 M rows -->
      <max_bytes_to_read>10000000000</max_bytes_to_read>       <!-- 10 GB -->
      <max_result_rows>100000</max_result_rows>
      <max_result_bytes>100000000</max_result_bytes>           <!-- 100 MB -->
      <max_threads>8</max_threads>
      <use_uncompressed_cache>0</use_uncompressed_cache>
      <load_balancing>random</load_balancing>
      <log_queries>1</log_queries>
      <log_query_threads>0</log_query_threads>
    </default>

    <!-- Ingest profile – optimised for high-throughput batch inserts. -->
    <ingest>
      <max_memory_usage>8000000000</max_memory_usage>          <!-- 8 GB -->
      <max_execution_time>600</max_execution_time>             <!-- 10 min -->
      <max_insert_block_size>1048576</max_insert_block_size>   <!-- 1 M rows -->
      <max_threads>4</max_threads>
      <async_insert>1</async_insert>
      <wait_for_async_insert>0</wait_for_async_insert>
      <async_insert_max_data_size>10000000</async_insert_max_data_size>   <!-- 10 MB -->
      <async_insert_busy_timeout_ms>1000</async_insert_busy_timeout_ms>
      <log_queries>1</log_queries>
    </ingest>

    <!-- Read-only profile for dashboards (Grafana). -->
    <readonly>
      <readonly>1</readonly>
      <max_memory_usage>2000000000</max_memory_usage>          <!-- 2 GB -->
      <max_execution_time>60</max_execution_time>              <!-- 1 min -->
      <max_rows_to_read>100000000</max_rows_to_read>           <!-- 100 M rows -->
      <max_result_rows>50000</max_result_rows>
      <max_threads>4</max_threads>
      <log_queries>1</log_queries>
    </readonly>

    <!-- Admin profile – elevated limits for DDL and maintenance. -->
    <admin>
      <max_memory_usage>16000000000</max_memory_usage>         <!-- 16 GB -->
      <max_execution_time>3600</max_execution_time>            <!-- 1 hr -->
      <max_rows_to_read>0</max_rows_to_read>                   <!-- unlimited -->
      <max_threads>16</max_threads>
      <log_queries>1</log_queries>
    </admin>

  </profiles>

  <!-- ─────────── Quotas ─────────── -->
  <quotas>

    <!-- Default quota – generous for dev. -->
    <default>
      <interval>
        <duration>3600</duration>
        <queries>1000</queries>
        <errors>100</errors>
        <result_rows>5000000</result_rows>
        <read_rows>1000000000</read_rows>
        <execution_time>3600</execution_time>
      </interval>
    </default>

    <!-- Ingest quota – higher throughput allowance. -->
    <ingest>
      <interval>
        <duration>3600</duration>
        <queries>50000</queries>
        <errors>500</errors>
        <result_rows>0</result_rows>  <!-- unlimited -->
        <read_rows>0</read_rows>
        <execution_time>36000</execution_time>
      </interval>
    </ingest>

    <!-- Readonly quota – throttled. -->
    <readonly_quota>
      <interval>
        <duration>3600</duration>
        <queries>500</queries>
        <errors>50</errors>
        <result_rows>2000000</result_rows>
        <read_rows>500000000</read_rows>
        <execution_time>1800</execution_time>
      </interval>
    </readonly_quota>

  </quotas>

  <!-- ─────────── Users ─────────── -->
  <users>

    <!--
      default – built-in ClickHouse user.
      No password (dev only). Restricted to localhost connections.
    -->
    <default>
      <password></password>
      <profile>default</profile>
      <quota>default</quota>
      <networks>
        <ip>127.0.0.1</ip>
        <ip>::1</ip>
      </networks>
      <access_management>1</access_management>
    </default>

    <!--
      kubric – main application user.
      Read/write access to kubric_telemetry database.
      Used by the ingest pipeline and API services.
    -->
    <kubric>
      <!-- SHA-256 of the dev password "kubric_dev_clickhouse_2024"
           Generate: echo -n 'kubric_dev_clickhouse_2024' | sha256sum -->
      <password_sha256_hex>a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2</password_sha256_hex>
      <profile>ingest</profile>
      <quota>ingest</quota>
      <networks>
        <ip>0.0.0.0/0</ip>
        <ip>::/0</ip>
      </networks>
      <allow_databases>
        <database>kubric_telemetry</database>
        <database>system</database>
      </allow_databases>
    </kubric>

    <!--
      kubric_readonly – read-only user for Grafana dashboards.
      Cannot modify data or schema.
    -->
    <kubric_readonly>
      <password_sha256_hex>b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3</password_sha256_hex>
      <profile>readonly</profile>
      <quota>readonly_quota</quota>
      <networks>
        <ip>0.0.0.0/0</ip>
        <ip>::/0</ip>
      </networks>
      <allow_databases>
        <database>kubric_telemetry</database>
        <database>system</database>
      </allow_databases>
    </kubric_readonly>

    <!--
      kubric_admin – administrative user for DDL and maintenance.
      Full access. Should be rotated via Vault in production.
    -->
    <kubric_admin>
      <password_sha256_hex>c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4</password_sha256_hex>
      <profile>admin</profile>
      <quota>default</quota>
      <networks>
        <ip>127.0.0.1</ip>
        <ip>::1</ip>
        <ip>10.0.0.0/8</ip>
        <ip>172.16.0.0/12</ip>
        <ip>192.168.0.0/16</ip>
      </networks>
      <access_management>1</access_management>
    </kubric_admin>

  </users>

</clickhouse>
