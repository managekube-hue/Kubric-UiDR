# ─────────────────────────────────────────────────────────────────────────────
# Kubric-UiDR — Earthfile (Reproducible Multi-Language Builds)
# Usage:  earthly +all
# ─────────────────────────────────────────────────────────────────────────────
VERSION 0.8

# ═══════════════════════════════════════════════════════════════════════════════
#  Base images
# ═══════════════════════════════════════════════════════════════════════════════
go-base:
    FROM golang:1.25.5-bookworm
    WORKDIR /src
    ENV CGO_ENABLED=0
    ENV GOFLAGS="-trimpath"
    RUN apt-get update && apt-get install -y --no-install-recommends \
        protobuf-compiler git ca-certificates && \
        rm -rf /var/lib/apt/lists/*

rust-base:
    FROM rust:1.81-bookworm
    WORKDIR /src
    RUN apt-get update && apt-get install -y --no-install-recommends \
        pkg-config libzmq3-dev libssl-dev && \
        rm -rf /var/lib/apt/lists/*
    RUN rustup component add clippy rustfmt

python-base:
    FROM python:3.12-bookworm
    WORKDIR /src
    RUN pip install --no-cache-dir --upgrade pip setuptools wheel

node-base:
    FROM node:20-bookworm-slim
    WORKDIR /src
    RUN corepack enable

# ═══════════════════════════════════════════════════════════════════════════════
#  Dependency caching
# ═══════════════════════════════════════════════════════════════════════════════
deps-go:
    FROM +go-base
    COPY go.mod go.sum ./
    COPY vendor/ ./vendor/
    RUN go mod download
    SAVE ARTIFACT go.mod
    SAVE ARTIFACT go.sum

deps-rust:
    FROM +rust-base
    COPY agents/Cargo.toml agents/Cargo.lock ./agents/
    COPY agents/coresec/Cargo.toml      ./agents/coresec/
    COPY agents/netguard/Cargo.toml     ./agents/netguard/
    COPY agents/perftrace/Cargo.toml    ./agents/perftrace/
    COPY agents/provisioning/Cargo.toml ./agents/provisioning/
    COPY agents/watchdog/Cargo.toml     ./agents/watchdog/
    # Create empty lib.rs files for dependency pre-build
    RUN for d in coresec netguard perftrace provisioning watchdog; do \
          mkdir -p agents/$d/src && echo "" > agents/$d/src/lib.rs; \
        done
    WORKDIR /src/agents
    RUN cargo fetch
    SAVE ARTIFACT Cargo.lock

deps-python:
    FROM +python-base
    COPY requirements.txt ./
    COPY kai/pyproject.toml kai/setup.cfg* kai/setup.py* ./kai/
    RUN pip install --no-cache-dir -r requirements.txt

deps-node:
    FROM +node-base
    COPY frontend/package.json frontend/package-lock.json ./frontend/
    WORKDIR /src/frontend
    RUN npm ci --prefer-offline
    SAVE ARTIFACT node_modules

# ═══════════════════════════════════════════════════════════════════════════════
#  Build targets
# ═══════════════════════════════════════════════════════════════════════════════
build-go:
    FROM +deps-go
    ARG VERSION="dev"
    ARG COMMIT="unknown"
    ARG BUILD_TIME="unknown"
    LET MODULE="github.com/managekube-hue/Kubric-UiDR"
    LET LDFLAGS="-s -w -X ${MODULE}/internal/version.Version=${VERSION} -X ${MODULE}/internal/version.Commit=${COMMIT} -X ${MODULE}/internal/version.BuildTime=${BUILD_TIME}"
    COPY cmd/       ./cmd/
    COPY internal/  ./internal/
    COPY config/    ./config/
    COPY db/        ./db/
    COPY services/  ./services/
    COPY proto/     ./proto/
    FOR bin IN ksvc vdr kic noc kbridges
        RUN go build -ldflags "${LDFLAGS}" -o /out/${bin} ./cmd/${bin}
        SAVE ARTIFACT /out/${bin} AS LOCAL build/bin/${bin}
    END

build-rust:
    FROM +deps-rust
    COPY agents/ ./agents/
    WORKDIR /src/agents
    RUN cargo build --release --workspace
    FOR agent IN coresec netguard perftrace provisioning watchdog
        SAVE ARTIFACT target/release/${agent} AS LOCAL build/bin/${agent}
    END

build-python:
    FROM +deps-python
    COPY kai/ ./kai/
    WORKDIR /src/kai
    RUN pip install --no-cache-dir -e .[dev]
    RUN python -m py_compile src/kai/__init__.py 2>/dev/null || true
    SAVE ARTIFACT /src/kai

build-frontend:
    FROM +deps-node
    COPY frontend/ ./frontend/
    WORKDIR /src/frontend
    ENV NEXT_TELEMETRY_DISABLED=1
    RUN npm run build
    SAVE ARTIFACT .next
    SAVE ARTIFACT public

# ═══════════════════════════════════════════════════════════════════════════════
#  Test targets
# ═══════════════════════════════════════════════════════════════════════════════
test-go:
    FROM +deps-go
    COPY cmd/       ./cmd/
    COPY internal/  ./internal/
    COPY config/    ./config/
    COPY db/        ./db/
    COPY services/  ./services/
    COPY proto/     ./proto/
    RUN go test -race -cover -count=1 ./...

test-rust:
    FROM +deps-rust
    COPY agents/ ./agents/
    WORKDIR /src/agents
    RUN cargo test --workspace

test-python:
    FROM +deps-python
    COPY kai/ ./kai/
    WORKDIR /src/kai
    RUN pip install --no-cache-dir -e .[dev]
    RUN python -m pytest tests/ -x -q --tb=short

test:
    BUILD +test-go
    BUILD +test-rust
    BUILD +test-python

# ═══════════════════════════════════════════════════════════════════════════════
#  Lint targets
# ═══════════════════════════════════════════════════════════════════════════════
lint-go:
    FROM +deps-go
    RUN go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.61.0
    COPY . .
    RUN golangci-lint run --timeout 5m ./...

lint-rust:
    FROM +deps-rust
    COPY agents/ ./agents/
    WORKDIR /src/agents
    RUN cargo clippy --workspace --all-targets -- -D warnings

lint-python:
    FROM +deps-python
    RUN pip install --no-cache-dir ruff mypy bandit
    COPY kai/ ./kai/
    WORKDIR /src/kai
    RUN ruff check .
    RUN mypy src/ --ignore-missing-imports

lint:
    BUILD +lint-go
    BUILD +lint-rust
    BUILD +lint-python

# ═══════════════════════════════════════════════════════════════════════════════
#  Docker images
# ═══════════════════════════════════════════════════════════════════════════════
docker-api:
    FROM gcr.io/distroless/static-debian12:nonroot
    ARG VERSION="dev"
    LABEL org.opencontainers.image.source="https://github.com/managekube-hue/Kubric-UiDR"
    LABEL org.opencontainers.image.version="${VERSION}"
    COPY +build-go/ksvc /usr/local/bin/ksvc
    COPY config/ /etc/kubric/
    EXPOSE 8080
    ENTRYPOINT ["/usr/local/bin/ksvc"]
    SAVE IMAGE --push ghcr.io/managekube-hue/kubric-uidr/api:${VERSION}
    SAVE IMAGE --push ghcr.io/managekube-hue/kubric-uidr/api:latest

docker-web:
    FROM node:20-bookworm-slim
    ARG VERSION="dev"
    LABEL org.opencontainers.image.source="https://github.com/managekube-hue/Kubric-UiDR"
    WORKDIR /app
    COPY +build-frontend/.next ./.next
    COPY +build-frontend/public ./public
    COPY +deps-node/node_modules ./node_modules
    COPY frontend/package.json ./
    ENV NODE_ENV=production
    ENV NEXT_TELEMETRY_DISABLED=1
    EXPOSE 3000
    CMD ["node_modules/.bin/next", "start"]
    SAVE IMAGE --push ghcr.io/managekube-hue/kubric-uidr/web:${VERSION}
    SAVE IMAGE --push ghcr.io/managekube-hue/kubric-uidr/web:latest

docker-agents:
    FROM debian:bookworm-slim
    ARG VERSION="dev"
    LABEL org.opencontainers.image.source="https://github.com/managekube-hue/Kubric-UiDR"
    RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates libzmq5 && \
        rm -rf /var/lib/apt/lists/*
    RUN useradd --system --no-create-home kubric
    FOR agent IN coresec netguard perftrace provisioning watchdog
        COPY +build-rust/${agent} /usr/local/bin/${agent}
    END
    USER kubric
    ENTRYPOINT ["/usr/local/bin/coresec"]
    SAVE IMAGE --push ghcr.io/managekube-hue/kubric-uidr/agents:${VERSION}
    SAVE IMAGE --push ghcr.io/managekube-hue/kubric-uidr/agents:latest

docker:
    BUILD +docker-api
    BUILD +docker-web
    BUILD +docker-agents

# ═══════════════════════════════════════════════════════════════════════════════
#  All
# ═══════════════════════════════════════════════════════════════════════════════
all:
    BUILD +build-go
    BUILD +build-rust
    BUILD +build-python
    BUILD +build-frontend
    BUILD +test
    BUILD +lint
    BUILD +docker
