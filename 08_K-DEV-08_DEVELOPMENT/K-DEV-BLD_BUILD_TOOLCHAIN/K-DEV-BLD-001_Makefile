# ───────────────────────────────────────────────────────────────────────────────
# Kubric-UiDR — Master Build Makefile
# Unified Security Detection & Response Platform
# ───────────────────────────────────────────────────────────────────────────────
SHELL          := /bin/bash
.DEFAULT_GOAL  := all

# ── Version / Registry ────────────────────────────────────────────────────────
VERSION        ?= $(shell git describe --tags --always --dirty 2>/dev/null || echo "0.0.0-dev")
COMMIT         := $(shell git rev-parse --short HEAD 2>/dev/null || echo "unknown")
BUILD_TIME     := $(shell date -u '+%Y-%m-%dT%H:%M:%SZ')
REGISTRY       ?= ghcr.io/managekube-hue/kubric-uidr
IMAGE_TAG      ?= $(VERSION)

# ── Tool paths ────────────────────────────────────────────────────────────────
GO             ?= go
CARGO          ?= cargo
PIP            ?= pip
NPM            ?= npm
BUF            ?= buf
DOCKER         ?= docker
DOCKER_COMPOSE ?= docker compose
MIGRATE        ?= migrate
GOLANGCI_LINT  ?= golangci-lint
K6             ?= k6

# ── Go settings ───────────────────────────────────────────────────────────────
MODULE         := github.com/managekube-hue/Kubric-UiDR
GO_LDFLAGS     := -s -w \
	-X $(MODULE)/internal/version.Version=$(VERSION) \
	-X $(MODULE)/internal/version.Commit=$(COMMIT) \
	-X $(MODULE)/internal/version.BuildTime=$(BUILD_TIME)
GO_BUILD_FLAGS := -trimpath -ldflags "$(GO_LDFLAGS)"
GO_BINARIES    := ksvc vdr kic noc kbridges
GO_BIN_DIR     := build/bin

# ── Rust settings ─────────────────────────────────────────────────────────────
CARGO_TARGET   := target/release
RUST_AGENTS    := coresec netguard perftrace provisioning watchdog

# ── Python settings ───────────────────────────────────────────────────────────
PYTHON         ?= python3
VENV           ?= .venv
KAI_DIR        := kai

# ── Frontend settings ─────────────────────────────────────────────────────────
FRONTEND_DIR   := frontend

# ── Docker images ─────────────────────────────────────────────────────────────
DOCKER_IMAGES  := api web agents

# ── Migration settings ────────────────────────────────────────────────────────
MIGRATIONS_DIR := migrations
DATABASE_URL   ?= postgres://kubric:kubric@localhost:5432/kubric?sslmode=disable

# ═══════════════════════════════════════════════════════════════════════════════
#  Meta targets
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: all build test lint fmt clean dev-up dev-down help

all: build-go build-rust build-python build-frontend ## Build everything

build: all

help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | \
		awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-22s\033[0m %s\n", $$1, $$2}'

# ═══════════════════════════════════════════════════════════════════════════════
#  Go
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: build-go test-go lint-go fmt-go

build-go: ## Build all Go binaries
	@echo "▸ Building Go binaries ($(VERSION))…"
	@mkdir -p $(GO_BIN_DIR)
	@for bin in $(GO_BINARIES); do \
		echo "  ◦ cmd/$$bin"; \
		CGO_ENABLED=0 $(GO) build $(GO_BUILD_FLAGS) -o $(GO_BIN_DIR)/$$bin ./cmd/$$bin; \
	done
	@echo "✓ Go binaries → $(GO_BIN_DIR)/"

test-go: ## Run Go tests with race detector
	@echo "▸ Running Go tests…"
	$(GO) test -race -cover -coverprofile=coverage-go.out -count=1 ./...
	@echo "✓ Go tests passed"

lint-go: ## Lint Go code
	@echo "▸ Linting Go…"
	$(GOLANGCI_LINT) run --timeout 5m ./...
	$(GO) vet ./...
	@echo "✓ Go lint passed"

fmt-go: ## Format Go code
	$(GO) fmt ./...
	goimports -w -local $(MODULE) .

# ═══════════════════════════════════════════════════════════════════════════════
#  Rust
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: build-rust test-rust lint-rust fmt-rust

build-rust: ## Build all Rust agents (release)
	@echo "▸ Building Rust agents…"
	cd agents && $(CARGO) build --release --workspace
	@echo "✓ Rust agents → agents/$(CARGO_TARGET)/"

test-rust: ## Run Rust tests
	@echo "▸ Running Rust tests…"
	cd agents && $(CARGO) test --workspace
	@echo "✓ Rust tests passed"

lint-rust: ## Lint Rust code
	@echo "▸ Linting Rust…"
	cd agents && $(CARGO) clippy --workspace --all-targets -- -D warnings
	@echo "✓ Rust lint passed"

fmt-rust: ## Format Rust code
	cd agents && $(CARGO) fmt --all

# ═══════════════════════════════════════════════════════════════════════════════
#  Python / KAI
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: build-python test-python lint-python

build-python: ## Install KAI in editable mode
	@echo "▸ Installing KAI…"
	$(PIP) install -e $(KAI_DIR)/[dev] --quiet
	@echo "✓ KAI installed"

test-python: ## Run Python / KAI tests
	@echo "▸ Running Python tests…"
	$(PYTHON) -m pytest $(KAI_DIR)/tests \
		--cov=$(KAI_DIR)/src \
		--cov-report=term-missing \
		--cov-report=xml:coverage-python.xml \
		-x -q --asyncio-mode=auto
	@echo "✓ Python tests passed"

lint-python: ## Lint Python code
	@echo "▸ Linting Python…"
	$(PYTHON) -m ruff check $(KAI_DIR)/
	$(PYTHON) -m mypy $(KAI_DIR)/src --ignore-missing-imports
	$(PYTHON) -m bandit -r $(KAI_DIR)/src -c pyproject.toml -q
	@echo "✓ Python lint passed"

# ═══════════════════════════════════════════════════════════════════════════════
#  Frontend (Next.js)
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: build-frontend test-frontend lint-frontend

build-frontend: ## Build Next.js frontend
	@echo "▸ Building frontend…"
	cd $(FRONTEND_DIR) && $(NPM) ci --prefer-offline && $(NPM) run build
	@echo "✓ Frontend built → $(FRONTEND_DIR)/.next/"

test-frontend: ## Run frontend tests
	cd $(FRONTEND_DIR) && $(NPM) test -- --ci --coverage

lint-frontend: ## Lint frontend
	cd $(FRONTEND_DIR) && $(NPM) run lint

# ═══════════════════════════════════════════════════════════════════════════════
#  Protobuf
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: proto-gen lint-proto

proto-gen: ## Generate protobuf code
	@echo "▸ Generating protobuf stubs…"
	$(BUF) generate proto/
	@echo "✓ Proto stubs generated"

lint-proto: ## Lint protobuf definitions
	@echo "▸ Linting protobuf…"
	$(BUF) lint proto/
	$(BUF) breaking proto/ --against '.git#branch=main'
	@echo "✓ Proto lint passed"

# ═══════════════════════════════════════════════════════════════════════════════
#  Combined targets
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: test lint fmt

test: test-go test-rust test-python ## Run all tests

lint: lint-go lint-rust lint-python lint-proto ## Lint everything

fmt: fmt-go fmt-rust ## Format all code
	cd $(KAI_DIR) && $(PYTHON) -m ruff format .
	cd $(FRONTEND_DIR) && $(NPM) run format

# ═══════════════════════════════════════════════════════════════════════════════
#  Docker
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: docker-build docker-push

docker-build: ## Build all Docker images
	@echo "▸ Building Docker images ($(IMAGE_TAG))…"
	$(DOCKER) build -t $(REGISTRY)/api:$(IMAGE_TAG)    -f Dockerfile.api    .
	$(DOCKER) build -t $(REGISTRY)/web:$(IMAGE_TAG)    -f Dockerfile.web    .
	$(DOCKER) build -t $(REGISTRY)/agents:$(IMAGE_TAG) -f Dockerfile.agents .
	@for img in $(DOCKER_IMAGES); do \
		$(DOCKER) tag $(REGISTRY)/$$img:$(IMAGE_TAG) $(REGISTRY)/$$img:latest; \
	done
	@echo "✓ Docker images built"

docker-push: ## Push all Docker images
	@echo "▸ Pushing Docker images…"
	@for img in $(DOCKER_IMAGES); do \
		$(DOCKER) push $(REGISTRY)/$$img:$(IMAGE_TAG); \
		$(DOCKER) push $(REGISTRY)/$$img:latest; \
	done
	@echo "✓ Docker images pushed"

# ═══════════════════════════════════════════════════════════════════════════════
#  Migrations
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: migrate-up migrate-down migrate-create

migrate-up: ## Apply all pending migrations
	@echo "▸ Running migrations up…"
	$(MIGRATE) -path $(MIGRATIONS_DIR) -database "$(DATABASE_URL)" up
	@echo "✓ Migrations applied"

migrate-down: ## Rollback the last migration
	@echo "▸ Rolling back last migration…"
	$(MIGRATE) -path $(MIGRATIONS_DIR) -database "$(DATABASE_URL)" down 1
	@echo "✓ Migration rolled back"

migrate-create: ## Create a new migration (usage: make migrate-create NAME=add_foo)
	@test -n "$(NAME)" || (echo "✗ NAME is required: make migrate-create NAME=add_foo" && exit 1)
	$(MIGRATE) create -ext sql -dir $(MIGRATIONS_DIR) -seq $(NAME)

# ═══════════════════════════════════════════════════════════════════════════════
#  Development environment
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: dev-up dev-down dev-logs

dev-up: ## Start local dev environment (docker-compose)
	@echo "▸ Starting dev environment…"
	$(DOCKER_COMPOSE) -f docker-compose.yml up -d --build
	@echo "✓ Dev environment running"
	@echo "  Portal  → http://localhost:3000"
	@echo "  API     → http://localhost:8080"
	@echo "  Grafana → http://localhost:3001"

dev-down: ## Stop local dev environment
	@echo "▸ Stopping dev environment…"
	$(DOCKER_COMPOSE) -f docker-compose.yml down -v --remove-orphans
	@echo "✓ Dev environment stopped"

dev-logs: ## Tail dev environment logs
	$(DOCKER_COMPOSE) -f docker-compose.yml logs -f --tail=100

# ═══════════════════════════════════════════════════════════════════════════════
#  Load testing
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: load-test-smoke load-test-full

load-test-smoke: ## Run K6 smoke test
	$(K6) run --env SCENARIO=smoke \
		08_K-DEV-08_DEVELOPMENT/K-DEV-TEST/K-DEV-TEST-001_k6_load_test.js

load-test-full: ## Run K6 full load test
	$(K6) run --env SCENARIO=load \
		08_K-DEV-08_DEVELOPMENT/K-DEV-TEST/K-DEV-TEST-001_k6_load_test.js

# ═══════════════════════════════════════════════════════════════════════════════
#  Clean
# ═══════════════════════════════════════════════════════════════════════════════
.PHONY: clean

clean: ## Remove all build artifacts
	@echo "▸ Cleaning…"
	rm -rf $(GO_BIN_DIR)
	rm -f coverage-go.out coverage-python.xml
	cd agents && $(CARGO) clean || true
	rm -rf $(FRONTEND_DIR)/.next $(FRONTEND_DIR)/node_modules/.cache
	find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name '*.pyc' -delete 2>/dev/null || true
	@echo "✓ Clean complete"
