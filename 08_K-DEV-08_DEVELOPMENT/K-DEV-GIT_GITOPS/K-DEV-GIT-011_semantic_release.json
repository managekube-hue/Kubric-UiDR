{
  "$schema": "https://json.schemastore.org/semantic-release.json",
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "type": "revert", "release": "patch" },
          { "type": "docs", "release": false },
          { "type": "style", "release": false },
          { "type": "chore", "release": false },
          { "type": "test", "release": false },
          { "type": "ci", "release": false },
          { "type": "build", "release": false },
          { "breaking": true, "release": "major" },
          { "scope": "no-release", "release": false }
        ],
        "parserOpts": {
          "noteKeywords": ["BREAKING CHANGE", "BREAKING-CHANGE"]
        }
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "Features", "hidden": false },
            { "type": "fix", "section": "Bug Fixes", "hidden": false },
            { "type": "perf", "section": "Performance", "hidden": false },
            { "type": "refactor", "section": "Refactoring", "hidden": false },
            { "type": "revert", "section": "Reverts", "hidden": false },
            { "type": "docs", "section": "Documentation", "hidden": true },
            { "type": "chore", "section": "Maintenance", "hidden": true },
            { "type": "ci", "section": "CI/CD", "hidden": true },
            { "type": "build", "section": "Build", "hidden": true },
            { "type": "test", "section": "Tests", "hidden": true }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md",
        "changelogTitle": "# Kubric-UiDR Changelog"
      }
    ],
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "build/bin/ksvc", "label": "ksvc (Go API server)" },
          { "path": "build/bin/vdr", "label": "vdr (Vendor ingestion)" },
          { "path": "build/bin/kic", "label": "kic (Ingestion controller)" },
          { "path": "build/bin/noc", "label": "noc (NOC service)" },
          { "path": "build/bin/kbridges", "label": "kbridges (Protocol bridges)" }
        ],
        "successComment": ":tada: This issue/PR is included in version ${nextRelease.version}.",
        "failComment": false,
        "labels": ["released"]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
