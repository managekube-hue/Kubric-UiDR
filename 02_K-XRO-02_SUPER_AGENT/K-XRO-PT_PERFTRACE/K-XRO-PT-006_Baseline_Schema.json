{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PerfTrace Baseline Schema",
  "description": "Schema for PerfTrace host metrics baseline snapshots stored in S3/MinIO. A baseline is captured over a 24-hour rolling window and used to detect anomalous performance deviations.",
  "type": "object",
  "required": [
    "schema_version",
    "hostname",
    "captured_at",
    "cpu",
    "memory",
    "disks",
    "networks"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Baseline schema version. Bump on breaking changes."
    },
    "hostname": {
      "type": "string",
      "minLength": 1,
      "description": "FQDN or short hostname of the monitored host."
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "description": "Kubric tenant identifier."
    },
    "agent_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique PerfTrace agent instance ID."
    },
    "captured_at": {
      "type": "integer",
      "minimum": 0,
      "description": "Unix epoch milliseconds at which the baseline snapshot was written."
    },
    "baseline_window_secs": {
      "type": "integer",
      "minimum": 3600,
      "default": 86400,
      "description": "Length of the rolling window (in seconds) over which the baseline was computed."
    },
    "sample_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of collection-cycle samples that contributed to this baseline."
    },
    "os_name": {
      "type": "string",
      "description": "Operating system name as reported by sysinfo."
    },
    "kernel_version": {
      "type": "string",
      "description": "Kernel version string."
    },
    "cpu": {
      "type": "object",
      "description": "CPU-level baseline statistics.",
      "required": ["core_count", "baseline_usage_pct"],
      "additionalProperties": false,
      "properties": {
        "brand": {
          "type": "string",
          "description": "CPU model string (e.g. 'Intel(R) Core(TM) i9-9900K')."
        },
        "core_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Logical CPU core count."
        },
        "frequency_mhz": {
          "type": "integer",
          "minimum": 0,
          "description": "CPU frequency in MHz."
        },
        "baseline_usage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Mean CPU usage percentage over the baseline window."
        },
        "p50_usage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Median (P50) CPU usage over the baseline window."
        },
        "p95_usage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "95th-percentile CPU usage over the 24-hour baseline window."
        },
        "p99_usage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "99th-percentile CPU usage over the 24-hour baseline window."
        },
        "stddev_usage_pct": {
          "type": "number",
          "minimum": 0,
          "description": "Standard deviation of CPU usage over the baseline window."
        }
      }
    },
    "memory": {
      "type": "object",
      "description": "Physical memory baseline statistics.",
      "required": ["total_bytes", "baseline_used_pct"],
      "additionalProperties": false,
      "properties": {
        "total_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total installed physical memory in bytes."
        },
        "baseline_used_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Mean memory usage percentage over the baseline window."
        },
        "p50_used_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "p95_used_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "95th-percentile memory usage over the baseline window."
        },
        "p99_used_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "stddev_used_pct": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "swap": {
      "type": "object",
      "description": "Swap / page-file baseline statistics.",
      "additionalProperties": false,
      "properties": {
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_used_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "p95_used_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "disks": {
      "type": "array",
      "description": "Per-mount-point disk baseline statistics.",
      "items": {
        "type": "object",
        "required": ["mount_point", "total_bytes", "baseline_usage_pct"],
        "additionalProperties": false,
        "properties": {
          "mount_point": {
            "type": "string",
            "minLength": 1,
            "description": "Mount point or drive letter (e.g. '/', 'C:\\')."
          },
          "name": {
            "type": "string",
            "description": "Device name (e.g. 'sda1', 'nvme0n1p1')."
          },
          "fs_type": {
            "type": "string",
            "description": "Filesystem type (e.g. 'ext4', 'xfs', 'NTFS')."
          },
          "total_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "baseline_usage_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Mean disk usage percentage over the baseline window."
          },
          "p95_usage_pct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "growth_bytes_per_hour": {
            "type": "number",
            "description": "Observed average disk growth rate in bytes per hour."
          }
        }
      }
    },
    "networks": {
      "type": "array",
      "description": "Per-interface network throughput baseline statistics.",
      "items": {
        "type": "object",
        "required": ["interface"],
        "additionalProperties": false,
        "properties": {
          "interface": {
            "type": "string",
            "minLength": 1,
            "description": "Network interface name (e.g. 'eth0', 'ens3')."
          },
          "baseline_bytes_per_sec_in": {
            "type": "number",
            "minimum": 0,
            "description": "Mean inbound throughput in bytes per second over the baseline window."
          },
          "baseline_bytes_per_sec_out": {
            "type": "number",
            "minimum": 0,
            "description": "Mean outbound throughput in bytes per second over the baseline window."
          },
          "p95_bytes_per_sec_in": {
            "type": "number",
            "minimum": 0
          },
          "p95_bytes_per_sec_out": {
            "type": "number",
            "minimum": 0
          },
          "baseline_packets_per_sec_in": {
            "type": "number",
            "minimum": 0
          },
          "baseline_packets_per_sec_out": {
            "type": "number",
            "minimum": 0
          },
          "baseline_error_rate_in": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Mean receive-error rate (errors / total packets) over the baseline window."
          },
          "baseline_error_rate_out": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "perf_counters": {
      "type": "object",
      "description": "Linux perf_event hardware counter baselines (all values are per-second rates). Absent when perf_event_open was unavailable.",
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "boolean",
          "description": "True if perf_event_open was accessible during the baseline window."
        },
        "baseline_cpu_cycles_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "p95_cpu_cycles_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_instructions_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "p95_instructions_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_cache_misses_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "p95_cache_misses_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_branch_misses_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_context_switches_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_page_faults_per_sec": {
          "type": "integer",
          "minimum": 0
        },
        "baseline_ipc": {
          "type": "number",
          "minimum": 0,
          "description": "Instructions-per-cycle ratio averaged over the baseline window."
        }
      }
    },
    "anomaly_thresholds": {
      "type": "object",
      "description": "Auto-computed thresholds derived from the baseline; breaching these triggers an alert.",
      "additionalProperties": false,
      "properties": {
        "cpu_alert_pct": {
          "type": "number",
          "description": "CPU usage percentage above which an anomaly is raised (default: p95 + 2*stddev)."
        },
        "memory_alert_pct": {
          "type": "number",
          "description": "Memory usage percentage above which an anomaly is raised."
        },
        "disk_alert_pct": {
          "type": "number",
          "description": "Disk usage percentage above which an anomaly is raised."
        },
        "net_bytes_per_sec_in_alert": {
          "type": "number",
          "description": "Inbound bytes/sec above which an anomaly is raised."
        }
      }
    }
  }
}
