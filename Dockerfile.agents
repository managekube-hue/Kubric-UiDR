# Kubric Agents — Multi-stage Rust build
# Produces runtime images for CoreSec, NetGuard, PerfTrace, Provisioning, Watchdog.
# eBPF ELF objects are compiled from vendor/ebpf/ C sources during the build.
#
# Usage:
#   docker build --target coresec     -t kubric/coresec:latest     .
#   docker build --target netguard    -t kubric/netguard:latest    .
#   docker build --target perftrace   -t kubric/perftrace:latest   .
#   docker build --target provisioning -t kubric/provisioning:latest .
#   docker build --target watchdog    -t kubric/watchdog:latest    .

# ?? Stage 1: eBPF compiler ???????????????????????????????????????????????????
# Compiles vendor/ebpf/*.c ? vendor/ebpf/*.o using clang/LLVM
FROM ubuntu:24.04 AS ebpf-builder

RUN apt-get update -y && apt-get install -y --no-install-recommends \
clang llvm libelf-dev libbpf-dev linux-headers-generic make ca-certificates \
&& rm -rf /var/lib/apt/lists/*

WORKDIR /src
COPY vendor/ebpf ./vendor/ebpf

# Build eBPF objects from C sources
RUN make -C vendor/ebpf

# ?? Stage 2: Rust build environment ??????????????????????????????????????????
FROM rust:1.88-slim-bookworm AS builder

RUN apt-get update -y && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev libpcap-dev clang llvm \
    make git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src

# Cache Cargo registry
COPY Cargo.toml Cargo.lock ./
COPY agents/coresec/Cargo.toml      agents/coresec/Cargo.toml
COPY agents/netguard/Cargo.toml     agents/netguard/Cargo.toml
COPY agents/perftrace/Cargo.toml    agents/perftrace/Cargo.toml
COPY agents/provisioning/Cargo.toml agents/provisioning/Cargo.toml
COPY agents/watchdog/Cargo.toml     agents/watchdog/Cargo.toml

# Dummy src files so cargo can cache deps without full source
RUN mkdir -p agents/coresec/src      && echo 'fn main(){}' > agents/coresec/src/main.rs
RUN mkdir -p agents/netguard/src     && echo 'fn main(){}' > agents/netguard/src/main.rs
RUN mkdir -p agents/perftrace/src    && echo 'fn main(){}' > agents/perftrace/src/main.rs
RUN mkdir -p agents/provisioning/src && echo 'fn main(){}' > agents/provisioning/src/main.rs
RUN mkdir -p agents/watchdog/src     && echo 'fn main(){}' > agents/watchdog/src/main.rs
RUN cargo fetch

# Copy full source
COPY agents ./agents
COPY vendor  ./vendor

# Copy compiled eBPF objects from stage 1
COPY --from=ebpf-builder /src/vendor/ebpf/execve_hook.o  vendor/ebpf/execve_hook.o
COPY --from=ebpf-builder /src/vendor/ebpf/openat2_hook.o vendor/ebpf/openat2_hook.o

# Build all agents in release mode
RUN cargo build --release \
    -p coresec \
    -p netguard \
    -p perftrace \
    -p provisioning \
    -p watchdog

# ?? Stage 3: slim runtime base ????????????????????????????????????????????????
FROM debian:bookworm-slim AS agent-runtime-base

RUN apt-get update -y && apt-get install -y --no-install-recommends \
    ca-certificates libpcap0.8 libssl3 \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN groupadd -r kubric && useradd -r -g kubric kubric

# ?? Stage 4: coresec runtime ??????????????????????????????????????????????????
FROM agent-runtime-base AS coresec

COPY --from=builder /src/target/release/coresec /usr/local/bin/coresec
# eBPF objects (compiled from C sources by ebpf-builder stage)
COPY --from=builder /src/vendor/ebpf/execve_hook.o  /opt/kubric/vendor/ebpf/execve_hook.o
COPY --from=builder /src/vendor/ebpf/openat2_hook.o /opt/kubric/vendor/ebpf/openat2_hook.o
# Detection rules — YARA-X and Sigma
COPY --from=builder /src/vendor/yara-rules           /opt/kubric/vendor/yara-rules
COPY --from=builder /src/vendor/sigma                /opt/kubric/vendor/sigma
# Threat intelligence — Suricata ET, Wazuh, Sysmon, Osquery, Velociraptor, rootcheck
COPY --from=builder /src/vendor/suricata             /opt/kubric/vendor/suricata
COPY --from=builder /src/vendor/wazuh-rules          /opt/kubric/vendor/wazuh-rules
COPY --from=builder /src/vendor/sysmon               /opt/kubric/vendor/sysmon
COPY --from=builder /src/vendor/osquery              /opt/kubric/vendor/osquery
COPY --from=builder /src/vendor/velociraptor         /opt/kubric/vendor/velociraptor
COPY --from=builder /src/vendor/rootcheck            /opt/kubric/vendor/rootcheck
COPY --from=builder /src/vendor/ipsum                /opt/kubric/vendor/ipsum
# Response assets — Cortex responders (Python, run via subprocess) + TheHive templates
COPY --from=builder /src/vendor/cortex               /opt/kubric/vendor/cortex
COPY --from=builder /src/vendor/thehive              /opt/kubric/vendor/thehive

# eBPF requires CAP_BPF + CAP_PERFMON (or root on older kernels)
ENV VENDOR_DIR=/opt/kubric/vendor \
    KUBRIC_YARA_DIR=/opt/kubric/vendor/yara-rules \
    KUBRIC_SIGMA_DIR=/opt/kubric/vendor/sigma/rules \
    KUBRIC_EBPF_EXECVE=/opt/kubric/vendor/ebpf/execve_hook.o \
    KUBRIC_EBPF_OPENAT=/opt/kubric/vendor/ebpf/openat2_hook.o
ENTRYPOINT ["/usr/local/bin/coresec"]

# ?? Stage 5: netguard runtime ?????????????????????????????????????????????????
FROM agent-runtime-base AS netguard

COPY --from=builder /src/target/release/netguard /usr/local/bin/netguard
# Network detection assets
COPY --from=builder /src/vendor/yara-rules /opt/kubric/vendor/yara-rules
COPY --from=builder /src/vendor/ipsum       /opt/kubric/vendor/ipsum
COPY --from=builder /src/vendor/suricata    /opt/kubric/vendor/suricata
COPY --from=builder /src/vendor/ndpi        /opt/kubric/vendor/ndpi
COPY --from=builder /src/vendor/zeek        /opt/kubric/vendor/zeek
COPY --from=builder /src/vendor/coreruleset /opt/kubric/vendor/coreruleset

ENV VENDOR_DIR=/opt/kubric/vendor \
    KUBRIC_NDPI_LIB_DIR=/opt/kubric/vendor/ndpi/lib \
    KUBRIC_ZEEK_SCRIPT_DIR=/opt/kubric/vendor/zeek/scripts \
    KUBRIC_CRS_DIR=/opt/kubric/vendor/coreruleset/rules
USER kubric
ENTRYPOINT ["/usr/local/bin/netguard"]

# ?? Stage 6: perftrace runtime ????????????????????????????????????????????????
FROM agent-runtime-base AS perftrace

COPY --from=builder /src/target/release/perftrace /usr/local/bin/perftrace
USER kubric
ENTRYPOINT ["/usr/local/bin/perftrace"]

# ?? Stage 7: provisioning runtime ????????????????????????????????????????????
FROM agent-runtime-base AS provisioning

COPY --from=builder /src/target/release/provisioning /usr/local/bin/provisioning
USER kubric
ENTRYPOINT ["/usr/local/bin/provisioning"]

# ?? Stage 8: watchdog runtime ?????????????????????????????????????????????????
FROM agent-runtime-base AS watchdog

COPY --from=builder /src/target/release/watchdog /usr/local/bin/watchdog
USER kubric
ENTRYPOINT ["/usr/local/bin/watchdog"]
