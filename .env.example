# =============================================================================
# Kubric UIDR — Environment Variables Template
# Copy to .env and fill in your values before running docker compose up
# =============================================================================

# ─── Tenant ──────────────────────────────────────────────────────────────────
KUBRIC_DEFAULT_TENANT=acme-corp

# ─── Databases ───────────────────────────────────────────────────────────────
KUBRIC_DATABASE_URL=postgresql://kubric:kubric@postgres:5432/kubric
KUBRIC_CLICKHOUSE_URL=clickhouse://default:@clickhouse:9000/kubric

# ─── NATS ────────────────────────────────────────────────────────────────────
KUBRIC_NATS_URL=nats://nats:4222

# ─── Vault ───────────────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# ─── LLM Inference ────────────────────────────────────────────────────────────
KUBRIC_OLLAMA_URL=http://ollama:11434
KUBRIC_MODEL_NAME=llama3.2
# KUBRIC_OPENAI_API_KEY=sk-...      # cloud fallback (optional)
# KUBRIC_ANTHROPIC_API_KEY=sk-...   # cloud fallback (optional)

# ─── n8n ─────────────────────────────────────────────────────────────────────
KUBRIC_N8N_BASE_URL=http://n8n:5678
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ─── Temporal ────────────────────────────────────────────────────────────────
KUBRIC_TEMPORAL_ADDRESS=temporal:7233

# ─── Stripe (billing) ────────────────────────────────────────────────────────
# KUBRIC_STRIPE_API_KEY=sk_test_...

# ─── Twilio / Vapi (voice alerts) ────────────────────────────────────────────
# KUBRIC_VAPI_API_KEY=...
# KUBRIC_VAPI_PHONE_NUMBER_ID=...
# KUBRIC_ALERT_PHONE_NUMBER=+1555...

# ─── Supabase (production Postgres) ──────────────────────────────────────────
# KUBRIC_DATABASE_URL=postgresql://postgres.REF:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# ─── ITSM / Composio ─────────────────────────────────────────────────────────
# KUBRIC_ZAMMAD_URL=https://your-zammad.example.com
# KUBRIC_ZAMMAD_TOKEN=...
# KUBRIC_COMPOSIO_API_KEY=...

# ─── MinIO (S3 storage) ───────────────────────────────────────────────────────
MINIO_ROOT_USER=kubric
MINIO_ROOT_PASSWORD=kubric-minio-secret
