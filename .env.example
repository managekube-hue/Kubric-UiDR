# Kubric Platform — Environment Variable Reference
# Copy to .env and fill in real values before running docker-compose.
# NEVER commit .env to git.

# ── PostgreSQL (main database) ─────────────────────────────────────────────
KUBRIC_DB_PASSWORD=changeme

# ── Temporal (workflow orchestration) ─────────────────────────────────────
TEMPORAL_DB_PASSWORD=changeme
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# ── NATS JetStream ─────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── ClickHouse ─────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme

# ── OpenAI / vLLM ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
VLLM_BASE_URL=http://localhost:8000/v1

# ── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Twilio ─────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=changeme
TWILIO_FROM_NUMBER=+15555555555

# ── HashiCorp Vault ────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=changeme

# ── Wazuh API ─────────────────────────────────────────────────────────────
WAZUH_API_USER=admin
WAZUH_API_PASSWORD=changeme
WAZUH_API_URL=https://localhost:55000

# ── VAPI.ai (voice calls) ─────────────────────────────────────────────────
VAPI_API_KEY=changeme

# ── Internal service URLs ──────────────────────────────────────────────────
NOC_API_URL=http://localhost:8100
SOC_API_URL=http://localhost:8101
GRC_API_URL=http://localhost:8102
PSA_API_URL=http://localhost:8103
KAI_API_URL=http://localhost:8000
