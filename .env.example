# Kubric Platform — Production Environment Variable Reference
# ============================================================
# Copy to .env and fill ALL values before running.
# NEVER commit .env to git — it is in .gitignore.
#
# Variable conventions:
#   KUBRIC_*          — KAI Python service (kai/config.py, prefix=KUBRIC_)
#   POSTGRES_*        — Docker Compose postgres container init
#   Everything else   — docker-compose or Go services read directly
#
# In production: these are stored in Vault and injected by External Secrets
# Operator or Vault Agent Injector. See scripts/vault-setup.sh.

# ─── Domain / Cluster ─────────────────────────────────────────────────────────
KUBRIC_DOMAIN=kubric.security          # your domain; used by Authentik + cert-manager

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=kubric
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD_32_CHARS
POSTGRES_DB=kubric
# Full connection URL used by Go services and KAI
KUBRIC_DATABASE_URL=postgresql://kubric:CHANGE_ME_DB_PASSWORD_32_CHARS@postgres:5432/kubric

# ─── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_USER=kubric
CLICKHOUSE_PASSWORD=CHANGE_ME_CH_PASSWORD_32_CHARS
CLICKHOUSE_DB=kubric
KUBRIC_CLICKHOUSE_URL=clickhouse://kubric:CHANGE_ME_CH_PASSWORD_32_CHARS@clickhouse:9000/kubric

# ─── NATS JetStream ───────────────────────────────────────────────────────────
KUBRIC_NATS_URL=nats://nats:4222
# For WebSocket access from browsers:
NEXT_PUBLIC_NATS_WS_URL=ws://nats:9222

# ─── HashiCorp Vault ──────────────────────────────────────────────────────────
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=CHANGE_ME_VAULT_ROOT_TOKEN
# For XRO agents (AppRole auth — see scripts/vault-setup.sh)
VAULT_ROLE_ID=CHANGE_ME_VAULT_ROLE_ID
VAULT_SECRET_ID=CHANGE_ME_VAULT_SECRET_ID

# ─── KAI AI Inference ─────────────────────────────────────────────────────────
KUBRIC_OLLAMA_URL=http://ollama:11434       # local LLM (preferred)
KUBRIC_MODEL_NAME=llama3.2                  # model to load in Ollama
KUBRIC_VLLM_URL=http://vllm:8000           # vLLM sidecar (optional)
KUBRIC_OPENAI_API_KEY=                      # cloud fallback — leave empty if using Ollama
KUBRIC_ANTHROPIC_API_KEY=                   # cloud fallback — leave empty if using Ollama

# ─── Temporal Workflow Engine ──────────────────────────────────────────────────
KUBRIC_TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_DB_PASSWORD=CHANGE_ME_TEMPORAL_DB_PASSWORD

# ─── Layer 1 Go Service URLs (KAI calls these) ────────────────────────────────
KUBRIC_KSVC_URL=http://k-svc:8080
KUBRIC_VDR_URL=http://vdr:8081
KUBRIC_KIC_URL=http://kic:8082
KUBRIC_NOC_URL=http://noc:8083
# Portal → KAI FastAPI
NEXT_PUBLIC_API_BASE=http://k-svc:8080
NEXT_PUBLIC_KAI_URL=http://kai:8101

# ─── JWT Signing (internal middleware/jwt.go) ──────────────────────────────────
KUBRIC_JWT_SECRET=CHANGE_ME_64_HEX_CHARS_JWT_SIGNING_KEY_HERE_00000000000000000000

# ─── Authentik SSO ────────────────────────────────────────────────────────────
# Get these from Authentik Admin → Applications → Kubric → Edit Provider
AUTHENTIK_CLIENT_ID=CHANGE_ME_AUTHENTIK_CLIENT_ID
AUTHENTIK_CLIENT_SECRET=CHANGE_ME_AUTHENTIK_CLIENT_SECRET
AUTHENTIK_ISSUER=https://auth.kubric.security/application/o/kubric/
# NextAuth secret — generate: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_32_HEX_CHARS
NEXTAUTH_URL=https://app.kubric.security

# ─── Stripe Billing ───────────────────────────────────────────────────────────
KUBRIC_STRIPE_API_KEY=sk_live_CHANGE_ME
KUBRIC_STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ─── Zammad ITSM (K-PSA / KAI-COMM) ──────────────────────────────────────────
KUBRIC_ZAMMAD_URL=https://helpdesk.kubric.security
KUBRIC_ZAMMAD_TOKEN=CHANGE_ME_ZAMMAD_API_TOKEN

# ─── Twilio (KAI-COMM voice alerts) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_AUTH_TOKEN
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
KUBRIC_ALERT_PHONE_NUMBER=+1XXXXXXXXXX   # number to call for critical alerts

# ─── Vapi.ai (AI phone calls for critical escalation) ─────────────────────────
KUBRIC_VAPI_API_KEY=CHANGE_ME_VAPI_API_KEY
KUBRIC_VAPI_PHONE_NUMBER_ID=CHANGE_ME_VAPI_PHONE_NUMBER_ID

# ─── Threat Intelligence APIs ─────────────────────────────────────────────────
KUBRIC_OTX_API_KEY=CHANGE_ME_OTX_KEY           # AlienVault OTX → https://otx.alienvault.com
KUBRIC_ABUSEIPDB_API_KEY=CHANGE_ME_ABUSEIPDB   # AbuseIPDB → https://www.abuseipdb.com/account/api
KUBRIC_NVD_API_KEY=CHANGE_ME_NVD               # NIST NVD → https://nvd.nist.gov/developers/request-an-api-key
KUBRIC_MISP_URL=https://misp.kubric.security   # your MISP instance
KUBRIC_MISP_API_KEY=CHANGE_ME_MISP_API_KEY

# ─── n8n Workflow Automation ──────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_N8N_KEY   # generate: openssl rand -hex 16
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_ADMIN_PW
KUBRIC_N8N_BASE_URL=http://n8n:5678
KUBRIC_N8N_WEBHOOK_URL=                         # optional override

# ─── MinIO (S3-compatible backup storage) ─────────────────────────────────────
MINIO_ROOT_USER=kubric
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD_16_CHARS

# ─── Neo4j (ITDR attack graph) ────────────────────────────────────────────────
NEO4J_AUTH=neo4j/CHANGE_ME_NEO4J_PASSWORD

# ─── Wazuh XDR (security events source) ──────────────────────────────────────
WAZUH_API_URL=https://wazuh-manager:55000
WAZUH_API_USER=admin
WAZUH_API_PASSWORD=CHANGE_ME_WAZUH_PASSWORD

# ─── Grafana ──────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GF_SERVER_ROOT_URL=https://grafana.kubric.security

# ─── Composio (GitHub/Jira/Slack integrations for KAI agents) ────────────────
KUBRIC_COMPOSIO_API_KEY=CHANGE_ME_COMPOSIO_API_KEY

# ─── KAI API Server ───────────────────────────────────────────────────────────
KUBRIC_API_HOST=0.0.0.0
KUBRIC_API_PORT=8101
KUBRIC_LOG_LEVEL=INFO

# ─── Tenant (required for KAI — set per-deployment or per-container) ──────────
# In K8s: set per-tenant via ConfigMap. In docker-compose dev: use any string.
KUBRIC_TENANT_ID=dev-tenant-01
