{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Kubric Platform Health — NATS, ClickHouse, Vault, Temporal, Agent heartbeat",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "NATS",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-kubric"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "mappings": [], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 10000}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "title": "NATS Consumer Lag",
      "type": "stat",
      "targets": [{"expr": "sum(nats_consumer_num_pending)", "legendFormat": "pending", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-kubric"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "ops"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 18, "x": 6, "y": 1},
      "id": 3,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single", "sort": "none"}},
      "title": "NATS Message Throughput",
      "type": "timeseries",
      "targets": [{"expr": "sum(rate(nats_messages_published_total[1m]))", "legendFormat": "published/s", "refId": "A"}, {"expr": "sum(rate(nats_messages_delivered_total[1m]))", "legendFormat": "delivered/s", "refId": "B"}]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 4,
      "title": "ClickHouse",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-kubric"},
      "fieldConfig": {
        "defaults": {"unit": "rows/s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 5,
      "title": "ClickHouse Insert Rate",
      "type": "timeseries",
      "targets": [{"expr": "rate(clickhouse_written_rows_total[1m])", "legendFormat": "rows/s", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-kubric"},
      "fieldConfig": {
        "defaults": {"unit": "bytes"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 6,
      "title": "ClickHouse Disk Usage",
      "type": "timeseries",
      "targets": [{"expr": "clickhouse_disks_free_space_bytes", "legendFormat": "free", "refId": "A"}, {"expr": "clickhouse_disks_total_space_bytes - clickhouse_disks_free_space_bytes", "legendFormat": "used", "refId": "B"}]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 7,
      "title": "Kubernetes — Pod Status",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-kubric"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 19},
      "id": 8,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "CrashLoopBackOff Pods",
      "type": "stat",
      "targets": [{"expr": "sum(kube_pod_container_status_waiting_reason{reason=\"CrashLoopBackOff\",namespace=\"kubric\"}) or vector(0)", "legendFormat": "pods", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus-kubric"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 19},
      "id": 9,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Vault Unsealed",
      "type": "stat",
      "targets": [{"expr": "vault_core_unsealed", "legendFormat": "unsealed", "refId": "A"}]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["kubric", "platform"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "utc",
  "title": "Kubric Platform Health",
  "uid": "kubric-platform",
  "version": 1
}
