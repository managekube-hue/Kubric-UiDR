{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "grafana-clickhouse-datasource", "name": "ClickHouse", "version": "3.0.0"}
  ],
  "annotations": {"list": []},
  "description": "Kubric per-tenant alert and compliance dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Active Alerts",
      "type": "row"
    },
    {
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Open Alerts",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
          "rawSql": "SELECT count() FROM kubric.kai_triage_results WHERE tenant_id = '${tenant_id}' AND status = 'open' AND created_at >= now() - INTERVAL 24 HOUR",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "Critical Vulnerabilities",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
          "rawSql": "SELECT count() FROM kubric.vuln_findings WHERE tenant_id = '${tenant_id}' AND severity = 'critical' AND status = 'open'",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}},
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "title": "KEV Matches",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
          "rawSql": "SELECT count() FROM kubric.nvd_cve WHERE in_kev = 1 AND tenant_id = '${tenant_id}'",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5},
      "id": 5,
      "title": "Compliance",
      "type": "row"
    },
    {
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "id": 6,
      "title": "Compliance Pass Rate by Framework",
      "type": "barchart",
      "targets": [
        {
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
          "rawSql": "SELECT framework, countIf(status='passed') / count() AS pass_rate FROM kubric.compliance_findings WHERE tenant_id = '${tenant_id}' GROUP BY framework ORDER BY framework",
          "refId": "A",
          "format": "table"
        }
      ]
    },
    {
      "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "id": 7,
      "title": "Recent Triage Events",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
          "rawSql": "SELECT created_at, severity, title, status FROM kubric.kai_triage_results WHERE tenant_id = '${tenant_id}' ORDER BY created_at DESC LIMIT 20",
          "refId": "A",
          "format": "table"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["kubric", "customer", "tenant"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "", "value": ""},
        "datasource": {"type": "grafana-clickhouse-datasource", "uid": "clickhouse-kubric"},
        "definition": "SELECT DISTINCT tenant_id FROM kubric.kubric_tenants ORDER BY tenant_id",
        "hide": 0,
        "includeAll": false,
        "label": "Tenant",
        "name": "tenant_id",
        "query": "SELECT DISTINCT tenant_id FROM kubric.kubric_tenants ORDER BY tenant_id",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "utc",
  "title": "Kubric Customer — Alerts & Compliance",
  "uid": "kubric-customer",
  "version": 1
}
